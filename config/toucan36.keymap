#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include <zmk-helpers/helper.h>
#include <zmk-helpers/key-labels/36.h>

/* ── Layer indices ─────────────────────────────────────────────────────────── */
#define BASE 0
#define NAV  1
#define NUM  2
#define FN   3
#define SYS  4

#include "combos.dtsi"

/* ── Readability shorthand ─────────────────────────────────────────────────── */
#define ___ &trans

/* ── Key-position groups (36-key: 5 cols × 3 rows + 3 thumbs/side)
 *
 *  LT4 LT3 LT2 LT1 LT0  RT0 RT1 RT2 RT3 RT4
 *  LM4 LM3 LM2 LM1 LM0  RM0 RM1 RM2 RM3 RM4
 *  LB4 LB3 LB2 LB1 LB0  RB0 RB1 RB2 RB3 RB4
 *      LH2 LH1 LH0       RH0 RH1 RH2
 * ─────────────────────────────────────────── */
#define KEYS_L LT0 LT1 LT2 LT3 LT4  LM0 LM1 LM2 LM3 LM4  LB0 LB1 LB2 LB3 LB4
#define KEYS_R RT0 RT1 RT2 RT3 RT4  RM0 RM1 RM2 RM3 RM4  RB0 RB1 RB2 RB3 RB4
#define THUMBS LH0 LH1 LH2 RH0 RH1 RH2

#include "include/hrm.dtsi"

/ {
    keymap {
        compatible = "zmk,keymap";

        /* BASE — QWERTY with timerless home-row mods (GACS order, pinky→index)
         *
         *  No outer columns vs. 42-key. Keys relocated:
         *    TAB   → left thumb 1 tap  (lt FN TAB)
         *    LCTRL → HRM on D          (hml LCTRL D)
         *    LSHFT → HRM on F          (hml LSHFT F)
         *    BSPC  → right thumb 1 tap (lt SYS BSPC)
         *    SQT   → NAV layer, RM4 slot (NAV + ;)
         *    ESC   → NAV layer, LT4 slot (NAV + Q)
         *
         *  Thumb cluster:
         *    L0: LGUI          L1: FN/TAB        L2: NAV/SPACE
         *    R0: NUM/RET       R1: SYS/BSPC      R2: RALT
         */
        base {
            display-name = "BASE";
            bindings = <
// ╭──────────────────┬──────────────────┬──────────────────┬──────────────────┬─────────╮ ╭─────────┬──────────────────┬──────────────────┬───────────────┬──────────────────╮
   &kp Q               &kp W              &kp E              &kp R              &kp T       &kp Y     &kp U              &kp I              &kp O           &kp P
// ├──────────────────┼──────────────────┼──────────────────┼──────────────────┼─────────┤ ├─────────┼──────────────────┼──────────────────┼───────────────┼──────────────────┤
   &hml LGUI A          &hml LALT S        &hml LCTRL D       &hml LSHFT F       &kp G       &kp H     &hmr RSHFT J       &hmr RCTRL K       &hmr RALT L     &hmr RGUI SEMI
// ├──────────────────┼──────────────────┼──────────────────┼──────────────────┼─────────┤ ├─────────┼──────────────────┼──────────────────┼───────────────┼──────────────────┤
   &kp Z               &kp X              &kp C              &kp V              &kp B       &kp N     &kp M              &kp COMMA          &kp DOT         &kp FSLH
// ╰──────────────────┴──────────────────┴──────────────────┼──────────────────┼─────────┤ ├─────────┼──────────────────┼──────────────────┼───────────────┴──────────────────╯
                                                              &kp LGUI           &lt FN TAB   &lt NAV SPACE   &lt NUM RET   &lt SYS BSPC   &kp RALT
//                                                           ╰──────────────────┴─────────╯ ╰─────────┴──────────────────┴──────────────────╯
            >;
        };

        /* NAV — navigation + one-shot mods
         *
         *  ESC placed at LT4 (NAV + Q).
         *  SQT placed at RM4 (NAV + ;) — fills the slot lost from the outer column.
         */
        nav {
            display-name = "NAV";
            bindings = <
// ╭──────────┬─────────┬─────────┬──────────┬─────╮ ╭───────────┬──────────┬──────────┬───────────┬─────────╮
   &kp ESC     ___       ___       ___         ___    &kp PG_UP   &kp BSPC   &kp UP     &kp DEL     ___
// ├──────────┼─────────┼─────────┼──────────┼─────┤ ├───────────┼──────────┼──────────┼───────────┼─────────┤
   &sk LGUI    &sk LALT  &sk LCTRL &sk LSHFT   ___    &kp PG_DN   &kp LEFT   &kp DOWN   &kp RIGHT   &kp SQT
// ├──────────┼─────────┼─────────┼──────────┼─────┤ ├───────────┼──────────┼──────────┼───────────┼─────────┤
   ___          ___       ___       ___         ___    &kp INS     &kp TAB    ___        ___         ___
// ╰──────────┴─────────┴─────────┼──────────┼─────┤ ├───────────┼──────────┼──────────┼───────────┴─────────╯
                                    ___         ___    ___         ___        ___        ___
//                                 ╰──────────┴─────╯ ╰───────────┴──────────┴──────────┴─────╯
            >;
        };

        /* NUM — numpad-style numbers with HRMs for modifier access */
        num {
            display-name = "NUM";
            bindings = <
// ╭─────┬──────────┬──────────┬──────────┬─────╮ ╭─────┬─────┬─────┬─────┬─────╮
   ___     &kp N7    &kp N8     &kp N9     ___    ___   ___   ___   ___   ___
// ├─────┼──────────┼──────────┼──────────┼─────┤ ├─────┼─────┼─────┼─────┼─────┤
   &hml LGUI N0   &hml LALT N4   &hml LCTRL N5   &hml LSHFT N6   ___    ___   ___   ___   ___   ___
// ├─────┼──────────┼──────────┼──────────┼─────┤ ├─────┼─────┼─────┼─────┼─────┤
   ___     &kp N1    &kp N2     &kp N3     ___    ___   ___   ___   ___   ___
// ╰─────┴──────────┴──────────┼──────────┼─────┤ ├─────┼─────┼─────┼─────┴─────╯
                                ___        ___    ___   ___   ___   ___
//                             ╰──────────┴─────╯ ╰─────┴─────┴─────┴─────╯
            >;
        };

        /* FN — function keys + media controls
         *
         *  Right thumbs: mute + play/pause while FN is held
         */
        fn {
            display-name = "FN";
            bindings = <
// ╭──────────┬──────────┬──────────┬──────────┬─────╮ ╭─────┬───────────┬────────────┬────────────┬─────╮
   &kp F12     &kp F7     &kp F8     &kp F9     ___    ___   &kp C_PREV   &kp C_VOL_UP  &kp C_NEXT   ___
// ├──────────┼──────────┼──────────┼──────────┼─────┤ ├─────┼───────────┼────────────┼────────────┼─────┤
   &hml LGUI F11   &hml LALT F4   &hml LCTRL F5   &hml LSHFT F6   ___    ___   &kp LC(LEFT)   &kp C_VOL_DN   &kp LC(RIGHT)   ___
// ├──────────┼──────────┼──────────┼──────────┼─────┤ ├─────┼───────────┼────────────┼────────────┼─────┤
   &kp F10     &kp F1     &kp F2     &kp F3     ___    ___   &kp C_PP    &kp C_MUTE   ___          ___
// ╰──────────┴──────────┴──────────┼──────────┼─────┤ ├─────┼───────────┼────────────┼────────────┴─────╯
                                      ___        ___    ___   &kp C_MUTE   &kp C_PP   ___
//                                   ╰──────────┴─────╯ ╰─────┴───────────┴────────────┴─────╯
            >;
        };

        /* SYS — Bluetooth profile selection + system controls */
        sys {
            display-name = "SYS";
            bindings = <
// ╭──────────────┬──────────────┬──────────────┬──────────────┬──────────────╮ ╭─────┬─────┬─────┬─────┬──────────────╮
   &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2   &bt BT_SEL 3   &bt BT_SEL 4   ___   ___   ___   ___   &out OUT_TOG
// ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤ ├─────┼─────┼─────┼─────┼──────────────┤
   &bt BT_CLR      ___            ___            ___            &bootloader      &bootloader   ___   ___   ___   ___
// ├──────────────┼──────────────┼──────────────┼──────────────┼──────────────┤ ├─────┼─────┼─────┼─────┼──────────────┤
   ___             ___            ___            ___            &sys_reset       &sys_reset   ___   ___   ___   &studio_unlock
// ╰──────────────┴──────────────┴──────────────┼──────────────┼──────────────┤ ├─────┼─────┼─────┼─────┴──────────────╯
                                                  ___            ___              ___   ___   ___   ___
//                                               ╰──────────────┴──────────────╯ ╰─────┴─────┴─────┴─────╯
            >;
        };

        extra_1 {
                status = "reserved";
        };

        extra_2 {
                status = "reserved";
        };

        extra_3 {
                status = "reserved";
        };
    };
};
